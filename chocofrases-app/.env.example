# ─── DATABASE ───────────────────────────────────────────────
DB_USER=chocofrases
DB_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://chocofrases:change_me_strong_password@postgres:5432/chocofrases

# ─── REDIS ──────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379

# ─── WHATSAPP CLOUD API (Meta) ──────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# ─── OPENAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key

# ─── TELEGRAM ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_team_group_chat_id

# ─── AIRTABLE ───────────────────────────────────────────────
AIRTABLE_API_KEY=your_airtable_personal_access_token
AIRTABLE_BASE_ID=your_airtable_base_id
AIRTABLE_ORDERS_TABLE=Pedidos
AIRTABLE_CLIENTS_TABLE=Clientes
AIRTABLE_PRODUCTS_TABLE=Productos

# ─── GOOGLE DRIVE ───────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=change_me_very_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── APP ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://yourdomain.com.ar
API_URL=https://api.yourdomain.com.ar

# ─── BUSINESS CONFIG ────────────────────────────────────────
BUSINESS_NAME=Chocofrases
BUSINESS_PHONE=+54911xxxxxxxx
BUSINESS_EMAIL=contacto@chocofrases.com.ar
BUSINESS_ADDRESS=Córdoba, Argentina
LOW_STOCK_THRESHOLD=5
ORDER_APPROVAL_TIMEOUT_MINUTES=10
ATTENDANCE_START_HOUR=8
ATTENDANCE_END_HOUR=20
